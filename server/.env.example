# ══════════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — AUTÉNTICA BACKEND
#  Copia este archivo como .env para desarrollo local
#  En Render, configura estas variables en el dashboard
# ══════════════════════════════════════════════════════

# Llave SECRETA de Stripe (sk_test_... para pruebas, sk_live_... para producción)
STRIPE_SECRET_KEY=sk_test_TU_LLAVE_AQUI

# Llave de API de Anthropic para el chatbot
ANTHROPIC_API_KEY=sk-ant-TU_LLAVE_AQUI

# URL del frontend (Static Site de Render) — para CORS
# Ejemplo: https://autentica.onrender.com
FRONTEND_URL=https://TU-STATIC-SITE.onrender.com

# Puerto (Render lo asigna automáticamente, no cambies esto)
PORT=4242
